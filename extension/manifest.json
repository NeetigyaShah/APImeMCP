{
  "manifest_version": 3,
  "name": "APImeMCP Recorder",
  "version": "0.4.0",
  "description": "Record clicks, typing, and navigation in a tab and send the recording to a local APImeMCP server for replay.",
  "permissions": ["activeTab", "scripting", "cookies", "webNavigation"],
  "optional_host_permissions": ["http://*/*", "https://*/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
